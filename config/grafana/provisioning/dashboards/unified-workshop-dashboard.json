      "options": {
        "legend": {"displayMode": "table", "placement": "bottom", "showLegend": true},
        "tooltip": {"mode": "multi", "sort": "desc"}
      },
      "targets": [
        {
          "expr": "sum(rate(fintech_requests_total{status=~\"5..\"}[1m])) / sum(rate(fintech_requests_total[1m]))",
          "legendFormat": "Error Rate (5xx)",
          "refId": "A"
        },
        {
          "expr": "sum(rate(fintech_requests_total{status=~\"4..\"}[1m])) / sum(rate(fintech_requests_total[1m]))",
          "legendFormat": "Error Rate (4xx)",
          "refId": "B"
        }
      ],
      "title": "Error Rate",
