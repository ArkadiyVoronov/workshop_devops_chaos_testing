{
  "dashboard": {
    "title": "🚀 Workshop — Общий мониторинг",
    "tags": ["workshop"],
    "timezone": "browser",
    "panels": [
      {
        "id": 1,
        "title": "📊 Запросы в секунду (RPS)",
        "type": "graph",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
        "targets": [
          {
            "expr": "rate(http_requests_total[1m])",
            "legendFormat": "{{method}} {{endpoint}}",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "reqps",
            "min": 0
          }
        },
        "options": {
          "legend": {"displayMode": "table", "placement": "bottom"},
          "tooltip": {"mode": "single"}
        }
      },
      {
        "id": 2,
        "title": "⏱️ Время ответа (P95)",
        "type": "graph",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
        "targets": [
          {
            "expr": "histogram_quantile(0.95, rate(http_request_duration_seconds_bucket[1m]))",
            "legendFormat": "P95",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "s",
            "min": 0
          }
        }
      },
      {
        "id": 3,
        "title": "❌ Ошибки (Error Rate)",
        "type": "gauge",
        "gridPos": {"h": 6, "w": 6, "x": 0, "y": 8},
        "targets": [
          {
            "expr": "sum(rate(http_requests_total{status=~\"5..\"}[1m])) / sum(rate(http_requests_total[1m])) * 100",
            "legendFormat": "% ошибок",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "min": 0,
            "max": 100,
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"color": "green", "value": 0},
                {"color": "yellow", "value": 1},
                {"color": "red", "value": 5}
              ]
            }
          }
        }
      },
      {
        "id": 4,
        "title": "💾 Использование CPU контейнерами",
        "type": "graph",
        "gridPos": {"h": 8, "w": 12, "x": 6, "y": 8},
        "targets": [
          {
            "expr": "rate(container_cpu_usage_seconds_total{name!=\"\"}[1m]) * 100",
            "legendFormat": "{{name}}",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "min": 0
          }
        }
      },
      {
        "id": 5,
        "title": "️ Использование памяти контейнерами",
        "type": "graph",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 16},
        "targets": [
          {
            "expr": "container_memory_usage_bytes{name!=\"\"} / 1024 / 1024",
            "legendFormat": "{{name}}",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "decmbytes",
            "min": 0
          }
        }
      },
      {
        "id": 6,
        "title": "🔄 Статусы HTTP ответов",
        "type": "piechart",
        "gridPos": {"h": 8, "w": 6, "x": 12, "y": 16},
        "targets": [
          {
            "expr": "sum by (status) (rate(http_requests_total[5m]))",
            "legendFormat": "{{status}}",
            "refId": "A"
          }
        ]
      },
      {
        "id": 7,
        "title": "📡 Сетевой трафик (приложение)",
        "type": "graph",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 24},
        "targets": [
          {
            "expr": "rate(container_network_receive_bytes_total{name=\"app\"}[1m]) * 8",
            "legendFormat": "Входящий",
            "refId": "A"
          },
          {
            "expr": "rate(container_network_transmit_bytes_total{name=\"app\"}[1m]) * 8",
            "legendFormat": "Исходящий",
            "refId": "B"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "bps"
          }
        }
      },
      {
        "id": 8,
        "title": " Информация о сервисах",
        "type": "stat",
        "gridPos": {"h": 4, "w": 24, "x": 0, "y": 32},
        "targets": [
          {
            "expr": "up{job=\"app\"}",
            "legendFormat": "Приложение",
            "refId": "A"
          },
          {
            "expr": "up{job=\"db\"}",
            "legendFormat": "База данных",
            "refId": "B"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "mappings": [
              {"options": {"0": {"text": "❌ Недоступен"}, "1": {"text": "✅ Работает"}}, "type": "value"}
            ],
            "thresholds": {
              "steps": [
                {"color": "red", "value": 0},
                {"color": "green", "value": 1}
              ]
            }
          }
        }
      }
    ],
    "refresh": "5s",
    "time": {
      "from": "now-15m",
      "to": "now"
    }
  }
}
